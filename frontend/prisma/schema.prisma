generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdminUser {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         String
  status       String   // "active" | "disabled"
  createdBy    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AdminRole {
  id          String   @id @default(uuid())
  key         String   @unique
  label       String
  builtin     Boolean
  permissions String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(uuid())
  adminEmail String
  action     String
  entity     String
  entityId   String?
  before     Json?
  after      Json?
  ts         DateTime @default(now())
}

model PricingConfig {
  id            String    @id @default(uuid())
  planId        String
  basePriceInr  Int
  offerPriceInr Int?
  offerEndsAt   DateTime?
  publishedAt   DateTime  @default(now())
}

model PricingRevision {
  id             String   @id @default(uuid())
  configSnapshot Json
  adminEmail     String
  ts             DateTime @default(now())
}

model Coupon {
  id         String   @id @default(uuid())
  code       String   @unique
  planScope  String
  lane       String
  discount   String
  amountOff  Int?
  maxUses    Int
  usedCount  Int      @default(0)
  status     String
  expiresAt  DateTime
  createdBy  String?
  createdAt  DateTime @default(now())
}

model CouponRedemption {
  id        String   @id @default(uuid())
  couponId  String
  sessionId String?
  tenantId  String?
  ipHash    String?
  ts        DateTime @default(now())
}

model Payment {
  id                String   @id @default(uuid())
  razorpayOrderId   String?
  razorpayPaymentId String?
  amount            Int
  plan              String
  status            String
  source            String
  sessionId         String?
  userId            String?
  familyProfileId   String?
  tenantId          String?
  couponId          String?
  refundReason      String?
  ts                DateTime @default(now())

  @@index([userId])
  @@index([familyProfileId])
}

model CompanionGrant {
  id        String    @id @default(uuid())
  sessionId String
  source    String
  plan      String?
  expiresAt DateTime?
  ts        DateTime  @default(now())
  passkey   String?

  @@index([sessionId])
  @@index([passkey])
}

model Invoice {
  id         String   @id @default(uuid())
  seq        Int      @unique @default(autoincrement())
  paymentId  String   @unique
  plan       String
  planName   String
  grossInr   Int
  taxableInr Int
  gstInr     Int
  gstRate    Float    @default(0.18)
  buyerName  String?
  buyerEmail String?
  sessionId  String?
  status     String   @default("issued")
  ts         DateTime @default(now())

  @@index([sessionId])
}

model CrmContact {
  id               String   @id @default(uuid())
  sessionId        String?
  tenantId         String?
  email            String?
  lane             String
  stage            String
  assignee         String?
  aiStatus         String?
  customFeeCharged Int?
  paymentStatus    String?
  createdAt        DateTime @default(now())
}

model CrmTask {
  id        String    @id @default(uuid())
  contactId String?
  title     String
  dueAt     DateTime?
  status    String
  assignee  String?
  createdAt DateTime  @default(now())
}

model CrmNote {
  id         String   @id @default(uuid())
  contactId  String
  adminEmail String
  body       String
  ts         DateTime @default(now())
}

model Document {
  id          String    @id @default(uuid())
  sessionId   String?
  connector   String?
  parseStatus String
  error       String?
  uploadedAt  DateTime  @default(now())
  deletedAt   DateTime?
}

model DeletionRequest {
  id          String    @id @default(uuid())
  sessionId   String?
  email       String?
  status      String
  requestedAt DateTime  @default(now())
  completedAt DateTime?
}

model SupportTicket {
  id        String   @id @default(uuid())
  lane      String
  sessionId String?
  subject   String
  body      String?
  rating    Int?
  tag       String?
  status    String
  assignee  String?
  ts        DateTime @default(now())
}

model Tenant {
  id               String   @id @default(uuid())
  firmName         String
  applicantName    String?
  icaiNo           String?
  email            String?
  passwordHash     String?
  city             String?
  status           String
  walletBalance    Int      @default(0)
  creditsAvailable Int?
  reviewedBy       String?
  reviewReason     String?
  createdAt        DateTime @default(now())
}

model B2CUser {
  id               String   @id @default(uuid())
  name             String
  email            String   @unique
  passwordHash     String
  referredBy       String?
  status           String   @default("active") // "active" | "blocked"
  flagReason       String?  // set when an admin flags this account for review
  createdBy        String?  // admin email when created from the admin panel
  filingsRemaining Int      @default(0) // wallet credits for multi-person filing packs
  createdAt        DateTime @default(now())
}

/// Someone the account holder files ITR for (self, client, or family member).
/// One login can manage up to N profiles; each stores its own draft and unlock.
model FamilyProfile {
  id            String    @id @default(uuid())
  userId        String
  name          String
  relationship  String    @default("self") // self | spouse | father | mother | son | daughter | sibling | client | other
  pan           String?
  dob           String?
  filingStatus  String    @default("not_started") // not_started | in_progress | filed
  draftJson     Json?
  unlockedPlanId String?
  unlockedAt    DateTime?
  lastPaymentId String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId])
}

model SessionEvent {
  id        String   @id @default(uuid())
  sessionId String
  eventName String
  payload   Json?
  ts        DateTime @default(now())
}

model Blog {
  id             String   @id @default(uuid())
  title          String
  slug           String   @unique
  coverImage     String?
  content        String   @db.Text
  focusKeyword   String?
  seoTitle       String?
  seoDescription String?
  status         String
  seoScore       Int      @default(0)
  authorId       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ReferralConfig {
  id                  String   @id @default("singleton")
  referrerRewardCoins Int      @default(100)
  refereeDiscountPct  Int      @default(10)
  maxCoinUsePerFiling Int      @default(25)
  updatedAt           DateTime @updatedAt
  updatedBy           String?
}

model ReferralCode {
  id         String   @id @default(uuid())
  code       String   @unique
  ownerEmail String
  createdAt  DateTime @default(now())
}

model ReferralRedemption {
  id                String   @id @default(uuid())
  referralCodeId    String
  redeemerSessionId String?
  paymentId         String?
  rewardGranted     Boolean  @default(false)
  createdAt         DateTime @default(now())
}

model B2CWallet {
  id        String   @id @default(uuid())
  email     String   @unique
  coins     Int      @default(0)
  updatedAt DateTime @updatedAt
}
