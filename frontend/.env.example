# Razorpay — required for live payments (mock orders used when unset)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your_secret_here

# Signed payment session cookie (P2-6) — falls back to RAZORPAY_KEY_SECRET if unset
PAYMENT_SESSION_SECRET=your_session_signing_secret

# Public app URL for callbacks (optional in dev)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Tax engine — production proxies to Vercel Python at /_/backend/api/compute
# Optional override for a hosted engine (Railway/Fly). Must end with /api/compute or host root.
# NEXT_PUBLIC_ENGINE_URL=https://your-engine.example.com/api/compute

# PostHog analytics (optional — noop provider when unset)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# AI summary for ITR analytics panel (optional — parsed data shown without AI)
# OpenAI-compatible API: set AI_API_KEY; optional AI_API_BASE_URL and AI_MODEL
AI_API_KEY=
AI_API_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini

# Document AI pipeline (AIS / CAMS / 26AS analyze) — both required or analyze returns 503
GEMINI_API_KEY=
OPENAI_API_KEY=

# Blog admin upload token (required for /blogs/upload and POST /api/blogs)
BLOG_ADMIN_TOKEN=your-secret-admin-token

# Testing — bypass companion paywall without Razorpay (local + Vercel preview/prod)
# Set to "true" to unlock companion guide and skip checkout. Leave unset in real production.
# Required on Vercel production for live testing — value is inlined at build time.
# NEXT_PUBLIC_BYPASS_PAYMENT=true
# Alias for production testing (same client behavior as BYPASS_PAYMENT)
# NEXT_PUBLIC_TESTING_MODE=true
# Server-only alias (API routes only — does NOT unlock client UI without a NEXT_PUBLIC_* flag)
# BYPASS_COMPANION_PAYWALL=true
